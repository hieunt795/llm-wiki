   "source": [
    "# Extract PDF → Markdown dùng Docling\n",
    "\n",
    "**Setup:** Mount Google Drive → chạy docling → output `.md` lưu thẳng vào Drive\n",
    "\n",
    "**Yêu cầu:** Upload folder `02_sources/books/` lên Google Drive trước\n",
    "- Đường dẫn mặc định: `My Drive/Wiki Link/02_sources/books/`"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Cell 1: Install docling ────────────────────────────────────────────────────\n",
    "!pip install docling -q"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Cell 2: Mount Google Drive ────────────────────────────────────────────────\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "import os\n",
    "from pathlib import Path\n",
    "\n",
    "# Đổi path này nếu bạn để folder ở chỗ khác trong Drive\n",
    "BOOKS_DIR = Path('/content/drive/MyDrive/Wiki Link/02_sources/books')\n",
    "\n",
    "# Verify\n",
    "if BOOKS_DIR.exists():\n",
    "    book_dirs = [d for d in BOOKS_DIR.iterdir() if d.is_dir()]\n",
    "    root_pdfs = list(BOOKS_DIR.glob('*.pdf'))\n",
    "    print(f'✅ Found {len(book_dirs)} book folders, {len(root_pdfs)} root PDFs')\n",
    "    for d in sorted(book_dirs):\n",
    "        pdfs = list(d.glob('*.pdf'))\n",
    "        mds  = list(d.glob('*.md'))\n",
    "        print(f'   {d.name}: {len(pdfs)} PDF, {len(mds)} MD')\n",
    "else:\n",
    "    print(f'❌ Path not found: {BOOKS_DIR}')\n",
    "    print('   Kiểm tra lại đường dẫn trong Drive')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Cell 3: Setup Docling converter ───────────────────────────────────────────\n",
    "from docling.document_converter import DocumentConverter, PdfFormatOption\n",
    "from docling.datamodel.pipeline_options import PdfPipelineOptions\n",
    "from docling.datamodel.document import ConversionStatus\n",
    "\n",
    "def make_converter(do_table_structure=True):\n",
    "    pipeline_options = PdfPipelineOptions(\n",
    "        do_ocr=False,\n",
    "        do_table_structure=do_table_structure,\n",
    "        generate_page_images=False,\n",
    "        generate_picture_images=False,\n",
    "    )\n",
    "    return DocumentConverter(\n",
    "        format_options={'pdf': PdfFormatOption(pipeline_options=pipeline_options)}\n",
    "    )\n",
    "\n",
    "# Load converter một lần, dùng lại cho tất cả PDF\n",
    "converter = make_converter(do_table_structure=True)\n",
    "print('✅ Docling converter ready')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Cell 4: Extract function ───────────────────────────────────────────────────\n",
    "def extract_pdf(pdf_path: Path, force: bool = False, skip_existing: bool = True) -> str:\n",
    "    \"\"\"\n",
    "    Extract 1 PDF → .md cùng thư mục.\n",
    "    Returns: 'ok', 'skip', 'partial', 'error'\n",
    "    \"\"\"\n",
    "    out_path = pdf_path.with_suffix('.md')\n",
    "\n",
    "    if skip_existing and not force and out_path.exists():\n",
    "        return 'skip'\n",
    "\n",
    "    try:\n",
    "        result = converter.convert(str(pdf_path))\n",
    "        status = result.status\n",
    "\n",
    "        if status not in (ConversionStatus.SUCCESS, ConversionStatus.PARTIAL_SUCCESS):\n",
    "            return 'error'\n",
    "\n",
    "        # Nếu partial → retry với table_structure=False\n",
    "        is_partial = (status == ConversionStatus.PARTIAL_SUCCESS)\n",
    "        if is_partial:\n",
    "            fallback = make_converter(do_table_structure=False)\n",
    "            r2 = fallback.convert(str(pdf_path))\n",
    "            if r2.status in (ConversionStatus.SUCCESS, ConversionStatus.PARTIAL_SUCCESS):\n",
    "                result = r2\n",
    "\n",
    "        md_body = result.document.export_to_markdown()\n",
    "\n",
    "        frontmatter = (\n",
    "            f'---\\n'\n",
    "            f'title: \"{pdf_path.stem}\"\\n'\n",
    "            f'type: raw_source\\n'\n",
    "            f'source_pdf: \"{pdf_path.name}\"\\n'\n",
    "            f'extractor: docling\\n'\n",
    "            f'---\\n\\n'\n",
    "        )\n",
    "\n",
    "        out_path.write_text(frontmatter + md_body, encoding='utf-8')\n",
    "        return 'partial' if is_partial else 'ok'\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f'    ERROR: {e}')\n",
    "        return 'error'\n",
    "\n",
    "print('✅ extract_pdf() ready')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Cell 5: Chạy extract toàn bộ ─────────────────────────────────────────────\n",
    "# Config\n",
    "FORCE         = False  # True = overwrite .md đã có\n",
    "SKIP_EXISTING = True   # True = bỏ qua PDF đã có .md\n",
    "\n",
    "# Collect tất cả PDFs\n",
    "all_pdfs = []\n",
    "for d in sorted(BOOKS_DIR.iterdir()):\n",
    "    if d.is_dir():\n",
    "        all_pdfs.extend(sorted(d.glob('*.pdf')))\n",
    "all_pdfs.extend(sorted(BOOKS_DIR.glob('*.pdf')))\n",
    "\n",
    "print(f'Total PDFs to process: {len(all_pdfs)}')\n",
    "print('-' * 60)\n",
    "\n",
    "results = {'ok': [], 'skip': [], 'partial': [], 'error': []}\n",
    "\n",
    "for i, pdf in enumerate(all_pdfs, 1):\n",
    "    rel = pdf.relative_to(BOOKS_DIR)\n",
    "    print(f'[{i}/{len(all_pdfs)}] {rel} ... ', end='', flush=True)\n",
    "    status = extract_pdf(pdf, force=FORCE, skip_existing=SKIP_EXISTING)\n",
    "    results[status].append(str(rel))\n",
    "    size_kb = pdf.with_suffix('.md').stat().st_size // 1024 if pdf.with_suffix('.md').exists() else 0\n",
    "    print(f'{status.upper()} ({size_kb} KB)')\n",
    "\n",
    "print('\\n' + '='*60)\n",
    "print(f'✅ OK:      {len(results[\"ok\"])}')\n",
    "print(f'⏭️  Skip:    {len(results[\"skip\"])}')\n",
    "print(f'⚠️  Partial: {len(results[\"partial\"])}')\n",
    "print(f'❌ Error:   {len(results[\"error\"])}')\n",
    "\n",
    "if results['error']:\n",
    "    print('\\nFailed files:')\n",
    "    for f in results['error']:\n",
    "        print(f'  - {f}')\n",
    "\n",
    "if results['partial']:\n",
    "    print('\\nPartial files (some pages missing):')\n",
    "    for f in results['partial']:\n",
    "        print(f'  - {f}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Cell 6 (Optional): Extract 1 book cụ thể ─────────────────────────────────\n",
    "# Dùng cell này để re-extract 1 book duy nhất\n",
    "\n",
    "BOOK_NAME = 'central_bank_balance_sheet'  # ← đổi tên book ở đây\n",
    "\n",
    "matches = [d for d in BOOKS_DIR.iterdir()\n",
    "           if d.is_dir() and BOOK_NAME.lower() in d.name.lower()]\n",
    "\n",
    "for book_dir in matches:\n",
    "    print(f'Book: {book_dir.name}')\n",
    "    for pdf in sorted(book_dir.glob('*.pdf')):\n",
    "        print(f'  {pdf.name} ... ', end='', flush=True)\n",
    "        status = extract_pdf(pdf, force=True)\n",
    "        size_kb = pdf.with_suffix('.md').stat().st_size // 1024 if pdf.with_suffix('.md').exists() else 0\n",
    "        print(f'{status.upper()} ({size_kb} KB)')"
   ],
   "execution_count": null,
   "outputs": []
  },
